{
  "stryker-config": {
    "solution": "../../ServantClaw.sln",
    "project": "ServantClaw.Application.csproj",
    "test-projects": [
      "../../tests/ServantClaw.UnitTests/ServantClaw.UnitTests.csproj"
    ],
    "since": {
      "enabled": false,
      "target": "main",
      "ignore-changes-in": ["**/obj/**", "**/bin/**", "**/*.generated.cs"]
    },
    "thresholds": { "high": 100, "low": 100, "break": 100 },
    "ignore-methods": ["*Log", "Log.*", "Console.Write*", "*Exception.ctor", "ConfigureAwait"],
    "reporters": ["progress", "html", "json", "cleartext"]
  }
}
